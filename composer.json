{
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0 || ^2.0",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.12",
        "phpstan/extension-installer": "^1.4",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "php-stubs/wordpress-stubs": "^6.6"
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpcs:fix": "phpcbf --standard=phpcs.xml.dist",
        "phpstan": "php -d memory_limit=1G vendor/phpstan/phpstan/phpstan analyse --memory-limit=1024M",
        "test": "phpunit --configuration tests/phpunit/phpunit.xml.dist --no-coverage",
        "lint": [
            "@phpcs"
        ],
        "check": [
            "@phpcs",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
